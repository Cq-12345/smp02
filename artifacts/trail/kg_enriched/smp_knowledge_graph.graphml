  <data key="d15">external_molecule_pool;vae_pretraining_domain</data>
  <data key="d12">ChEMBL 是外部候选池，不等价于 SMP 实验事实。</data>
</node>
<node id="local_functional_group_rules">
  <data key="d0">literature_source</data>
  <data key="d13">curated_rule_set</data>
  <data key="d14">docs/functional_group_classification_and_matching.md</data>
  <data key="d15">smarts_functional_groups;reaction_compatibility_harness</data>
  <data key="d12">由于主论文未公开完整 SMARTS/兼容性矩阵，本项目维护可审计的本地规则。</data>
</node>
<node id="candidate_source_registry">
  <data key="d0">literature_source</data>
  <data key="d13">local_registry</data>
  <data key="d14">trail/candidates/source_registry.yaml</data>
  <data key="d15">candidate_source_authority;sparse_functional_group_audit</data>
  <data key="d12">候选来源、权威等级和稀疏官能团扩展优先级。</data>
</node>
<node id="epoxy_amine_thermal_cure">
  <data key="d0">process_condition_template</data>
  <data key="d16">thermal</data>
  <data key="d17">optional_accelerator</data>
  <data key="d18">mix_temperature_c;cure_temperature_c;cure_time_h;post_cure_temperature_c;post_cure_time_h</data>
  <data key="d12">环氧-胺体系通常对当量比、升温程序和后固化敏感。</data>
</node>
<node id="epoxy_anhydride_catalyzed_cure">
  <data key="d0">process_condition_template</data>
  <data key="d16">thermal</data>
  <data key="d17">tertiary_amine_or_imidazole_optional</data>
  <data key="d18">catalyst_loading;cure_temperature_c;post_cure_temperature_c</data>
  <data key="d12">环氧-酸酐常需要催化剂；缺少催化剂时应降低工艺置信度。</data>
</node>
<node id="anhydride_amine_imidization">
  <data key="d0">process_condition_template</data>
  <data key="d16">thermal_or_solution_imidization</data>
  <data key="d17">optional</data>
  <data key="d18">solvent;imidization_temperature_c;imidization_time_h</data>
  <data key="d12">酸酐-胺路线可能先形成聚酰胺酸/酰胺酸，再进一步酰亚胺化。</data>
</node>
<node id="isocyanate_urethane_urea">
  <data key="d0">process_condition_template</data>
  <data key="d16">ambient_or_thermal</data>
  <data key="d17">tin_or_amine_optional</data>
  <data key="d18">moisture_control;nco_index;cure_temperature_c</data>
  <data key="d12">异氰酸酯体系对水分、NCO 指数和催化剂敏感。</data>
</node>
<node id="radical_vinyl_cure">
  <data key="d0">process_condition_template</data>
  <data key="d16">thermal_or_photo_radical</data>
  <data key="d17">peroxide_or_photoinitiator</data>
  <data key="d18">initiator_type;initiator_loading;irradiation_or_cure_temperature_c</data>
  <data key="d12">自由基体系必须记录引发剂和光/热触发方式。</data>
</node>
<node id="thiol_click_cure">
  <data key="d0">process_condition_template</data>
  <data key="d16">base_photo_or_radical</data>
  <data key="d17">base_or_photoinitiator_optional</data>
  <data key="d18">thiol_ene_stoichiometry;catalyst_or_initiator;cure_temperature_c</data>
  <data key="d12">thiol-ene/thiol-acrylate 对化学计量、碱/光引发和氧阻聚条件敏感。</data>
</node>
<node id="cyanate_ester_triazine_cure">
  <data key="d0">process_condition_template</data>
  <data key="d16">high_temperature_thermal</data>
  <data key="d17">metal_or_phenolic_catalyst_optional</data>
  <data key="d18">trimerization_temperature_c;catalyst_loading;post_cure_temperature_c</data>
  <data key="d12">氰酸酯常需高温三聚或催化；工艺条件对最终 Tg 影响很大。</data>
</node>
<node id="maleimide_addition_or_copolymerization">
  <data key="d0">process_condition_template</data>
  <data key="d16">thermal_or_michael_addition</data>
  <data key="d17">base_or_radical_optional</data>
  <data key="d18">cure_temperature_c;co_reactant_stoichiometry;post_cure_temperature_c</data>
  <data key="d12">马来酰亚胺可以 Michael 加成或共聚，需记录共反应物和触发方式。</data>
</node>
<node id="library">
  <data key="d0">candidate_source</data>
  <data key="d3">SMP_Dataset.xlsx 中已经出现的单体。</data>
  <data key="d19">high</data>
</node>
