</node>
<node id="rigid_multi_aromatic">
  <data key="d0">feature</data>
</node>
<node id="imide_anhydride_networks_raise_tg">
  <data key="d0">structural_principle</data>
  <data key="d6">raises_Tg</data>
  <data key="d7">imide_or_anhydride</data>
  <data key="d8">酰亚胺/酸酐路线常形成高刚性、高热稳定性网络。</data>
</node>
<node id="imide_or_anhydride">
  <data key="d0">feature</data>
</node>
<node id="cyanate_ester_triazine">
  <data key="d0">structural_principle</data>
  <data key="d6">raises_Tg</data>
  <data key="d7">cyanate_ester</data>
  <data key="d8">氰酸酯三聚生成三嗪网络，常用于高 Tg 热固性体系。</data>
</node>
<node id="cyanate_ester">
  <data key="d0">functional_group</data>
</node>
